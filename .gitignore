# Environment variables (contains API keys)
.env

# ChromaDB persistent storage
chroma_db/

# Python virtual environment
venv/
.venv/

# Python bytecode
__pycache__/
*.pyc

# User profile data (generated at runtime)
user_profiles/*.json

# Feedback logs (contain real user prompts — never commit)
feedback/

# Promoted examples log (generated at runtime from user sessions)
data/promoted_examples.jsonl
logs/proref.log