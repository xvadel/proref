# ──────────────────────────────────────────────────────────────
# Personalized Prompt Refiner v3.0 — Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ── LLM Provider ────────────────────────────────────────────────
# Options: "groq" (default, free tier) | "ollama" (fully local)
LLM_PROVIDER=groq

# ── Groq Configuration ──────────────────────────────────────────
# Get a free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Ollama Configuration (alternative, fully local) ─────────────
# Requires Ollama installed: https://ollama.ai
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Shared LLM Parameters ───────────────────────────────────────
# These apply to ALL LLM clients (Groq + Ollama) — change once here.
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=60

# ── Retry / Back-off Strategy ───────────────────────────────────
LLM_MAX_RETRIES=3
LLM_RETRY_MIN_WAIT=1.0
LLM_RETRY_MAX_WAIT=30.0

# ── ChromaDB Storage ────────────────────────────────────────────
# Path for persistent vector database storage (relative to project root)
CHROMA_DB_PATH=./chroma_db

# ── HuggingFace Specialist Pipelines ────────────────────────────
# Master switch: set to false on low-RAM machines to disable all HF models
# (the system will fall back to the LLM for all tasks, including translation)
HF_USE_PIPELINE=true

# Model identifiers — change to use alternative HuggingFace models
HF_TRANSLATION_MODEL=Helsinki-NLP/opus-mt-ar-en
HF_FINBERT_MODEL=ProsusAI/finbert
HF_SUMMARIZATION_MODEL=facebook/bart-large-cnn
HF_CODE_MODEL=microsoft/codebert-base
HF_ZEROSHOT_MODEL=facebook/bart-large-mnli
HF_SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
HF_CREATIVE_MODEL=gpt2

# ── Logging ─────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Directory for rotating log files (relative to project root)
LOG_DIR=logs
